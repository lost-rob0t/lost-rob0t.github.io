<div id="outline-container-org06af2e8" class="outline-4">
<h4 id="org06af2e8">shell.nix</h4>
<div class="outline-text-4" id="text-org06af2e8">
<p>
if you prefer to use `shell.nix`
then copy paste this into your shell.nix
</p>

<div class="org-src-container">
<pre class="src src-nix">with import &lt;nixpkgs&gt; {};
let
  manyLinuxFile =
    writeTextDir "_manylinux.py"
      ''
	print("in _manylinux.py")
	manylinux1_compatible = True
      '';
in
buildFHSUserEnv {
  name = "my-python-env";
  targetPkgs = pkgs: with pkgs; [
    python3
    pipenv
    which
    gcc
    binutils
    manyLinuxFile

    # playwright stuff
    playwright
    nodejs


    # All the C libraries that a manylinux_1 wheel might depend on:
    ncurses
    xorg.libX11
    xorg.libXext
    xorg.libXrender
    xorg.libICE
    xorg.libSM
    glib
    stdenv.cc.cc.lib
  ];

  runScript = "$SHELL";
}
</pre>
</div>
